# ====== FRONTEND (Vite) ======
# Supabase (mismo proyecto que usa el CRM)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# URL del backend de WhatsApp (servidor Express). En local:
VITE_WHATSAPP_API_URL=http://localhost:3001

# Coexistence (Embedded Signup): App ID público y Config ID del
# "Inicio de sesión con Facebook para empresas".
VITE_META_APP_ID=
VITE_META_CONFIG_ID=

# ====== BACKEND WhatsApp Cloud API (Meta) ======
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# Coexistence (uso simultáneo celular + CRM)
WHATSAPP_COEXISTENCE=true
WHATSAPP_HISTORY_DAYS=30

# Graph API
GRAPH_API_VERSION=v19.0

# Servidor del webhook
WHATSAPP_PORT=3001
WHATSAPP_PUBLIC_URL=

# Supabase para el backend (SERVICE ROLE: solo servidor, NUNCA en el frontend)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
WHATSAPP_MEDIA_BUCKET=whatsapp-media
